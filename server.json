{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.github.xinxinhenaixin/emailfinder-mcp",
  "description": "Find verified professional emails by name, domain, LinkedIn, or role.",
  "version": "1.0.3",
  "websiteUrl": "https://emailfinder.dev",
  "repository": {
    "url": "https://github.com/xinxinhenaixin/emailfinder-mcp",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "emailfinder-mcp",
      "version": "1.0.3",
      "runtimeHint": "npx",
      "runtimeArguments": [
        { "type": "positional", "value": "-y" },
        { "type": "positional", "value": "emailfinder-mcp" }
      ],
      "environmentVariables": [
        {
          "name": "EMAILFINDER_API_KEY",
          "description": "API key from emailfinder.dev/dashboard/settings",
          "isRequired": true,
          "isSecret": true
        }
      ],
      "transport": {
        "type": "stdio"
      }
    }
  ]
}
